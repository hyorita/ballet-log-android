<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Note: no READ_MEDIA_IMAGES — we use the system PhotoPicker
         (ActivityResultContracts.PickMultipleVisualMedia) which grants
         per-uri access without a runtime permission. -->

    <!-- YouTube thumbnail loading in note Reference Link cards -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Health Connect 퍼미션 -->
    <uses-permission android:name="android.permission.health.READ_EXERCISE" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />

    <!-- Android 11+ package visibility: needed for resolveActivity() to see
         Health Connect's settings activities and the Play Store fallback. -->
    <queries>
        <intent>
            <action android:name="android.health.connect.action.MANAGE_HEALTH_PERMISSIONS" />
        </intent>
        <intent>
            <action android:name="android.health.connect.action.HEALTH_HOME_SETTINGS" />
        </intent>
        <intent>
            <action android:name="androidx.health.ACTION_MANAGE_HEALTH_PERMISSIONS" />
        </intent>
        <intent>
            <action android:name="androidx.health.ACTION_HEALTH_CONNECT_SETTINGS" />
        </intent>
        <package android:name="com.google.android.apps.healthdata" />
        <package android:name="com.google.android.healthconnect.controller" />
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BalletLog">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.BalletLog">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:label="@string/app_name"
            android:theme="@style/Theme.BalletLog"
            android:windowSoftInputMode="adjustResize">
        </activity>

        <!-- Health Connect 퍼미션 선언 -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- FileProvider (share image cache) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
